# ============================================================
# WhatsApp API Gateway - Environment Configuration
# ============================================================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Master API Key (wajib diganti! digunakan untuk operasi admin)
MASTER_API_KEY=ganti-dengan-key-rahasia-yang-panjang

# Database SQLite (menyimpan metadata device)
DB_PATH=./data/gateway.db

# Folder sesi Baileys (satu folder per device)
SESSIONS_DIR=./sessions

# Redis (untuk BullMQ message queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# Anti-Spam Protection
# ============================================================

# Maksimal pesan per menit per device (rate limiter queue)
RATE_LIMIT_MESSAGES=20

# Delay minimum antar pesan (ms) - random delay anti-spam
MIN_DELAY_MS=1000

# Delay maksimum antar pesan (ms)
MAX_DELAY_MS=3500

# Batas pesan per hari per device (0 = tidak terbatas)
DAILY_MESSAGE_LIMIT=500

# ============================================================
# Webhook
# ============================================================

# Timeout webhook delivery (ms)
WEBHOOK_TIMEOUT_MS=10000

# ============================================================
# Logging
# ============================================================

# Level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
